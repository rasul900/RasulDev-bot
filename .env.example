BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=your_telegram_user_id
BOT_USERNAME=your_bot_username
MONGO_URI=mongodb://127.0.0.1:27017/telegram-bot

# ── Fragment (Stars / Premium avtomatlashtirish) ──────────────
# fragment.com ga Telegram akkaunt bilan kiring va TON hamyoningizni ulang.
# Brauzer DevTools -> Application -> Cookies dan quyidagilarni oling:
FRAGMENT_STEL_DT=-240
FRAGMENT_STEL_SSID=
FRAGMENT_STEL_TOKEN=
FRAGMENT_STEL_TON_TOKEN=

# ── TON hamyon (to'lov uchun) ─────────────────────────────────
# fragment.com ga ulangan hamyonning 24 so'zli seed (mnemonic) iborasi.
# Bo'sh joy bilan ajrating. MAXFIY! Hech kimga bermang.
TON_MNEMONIC=
# Ixtiyoriy: toncenter.com dan API kalit (rate limit uchun)
TON_API_KEY=
TON_ENDPOINT=https://toncenter.com/api/v2/jsonRPC

# ── Multicard (avtomatik balans to'ldirish) ───────────────────
# multicard.uz kabinetidan oling: application_id, store_id, secret
MULTICARD_APPLICATION_ID=
MULTICARD_SECRET=
MULTICARD_STORE_ID=
MULTICARD_API_URL=https://api.multicard.uz
MULTICARD_LANG=uz

# Qabul qiluvchi karta (qo'lda o'tkazish uchun)
PAYMENT_CARD_NUMBER=9860 2466 0223 7355
PAYMENT_CARD_HOLDER=A.A

# Webhook uchun HTTPS manzil (ixtiyoriy)
# Bo'lmasa bot polling rejimida ishlaydi — domen sotib olish shart emas
# Masalan: https://your-app.justrunmy.app
PAYMENT_PUBLIC_URL=
PAYMENT_PORT=3000
PAYMENT_POLL_MS=30000

# ── SMM Panel API (smmsb.uz) ──────────────────────────────────
SMM_API_URL=https://smmsb.uz/Chaqmoqsmmuzbot/api/v2
SMM_API_KEY=
SMM_MARKUP_PERCENT=15
SMS_PAYMENT_ENABLED=true
SMS_WEBHOOK_SECRET=your_random_secret

# OFD (fiskal chek) — Multicard kabinetidagi MXIK kodingiz
MULTICARD_OFD_MXIK=85991900000000000
MULTICARD_OFD_PACKAGE_CODE=1506113
MULTICARD_OFD_NAME=Balans to'ldirish
